# ─────────────────────────────────────────────────────────────
# Copy this file to .env and fill in real values:
#   cp .env.example .env
# .env is NOT committed to the repository (see .gitignore).
# ─────────────────────────────────────────────────────────────

# Bot token from @BotFather (/newbot command).
BOT_TOKEN=123456789:AA-your-telegram-bot-token-here

# Neon connection string (Dashboard → Connection Details → string with ?sslmode=require).
DATABASE_URL=postgresql://user:password@ep-xxx.eu-central-1.aws.neon.tech/dbname?sslmode=require

# Your personal Telegram id (ask @userinfobot). This user becomes admin on the
# first /start (self-registration).
ADMIN_TELEGRAM_ID=123456789

# ─── Optional (have defaults) ───

# Quiet-hours time zone (future groundwork). Default Asia/Tashkent.
# TIMEZONE=Asia/Tashkent

# Working-hours bounds for auto-broadcast (future groundwork), 0–23.
# WORK_START=8
# WORK_END=21
