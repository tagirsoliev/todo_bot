{
  "name": "reminder-bot",
  "version": "1.0.0",
  "description": "Telegram-бот «Напоминалка задач» (grammY + Neon + Drizzle)",
  "author": "Tagir Soliev",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@grammyjs/conversations": "^2.1.0",
    "@neondatabase/serverless": "^1.1.0",
    "dotenv": "^17.4.0",
    "drizzle-orm": "^0.45.0",
    "grammy": "^1.44.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "drizzle-kit": "^0.31.0",
    "tsx": "^4.23.0",
    "typescript": "^5.7.0"
  }
}
